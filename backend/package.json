{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "migrate": "node scripts/migrate.js",
    "migrate:up": "node-pg-migrate up --migrations-dir migrations",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config vitest.config.js",
    "test:integration": "vitest run --config vitest.integration.config.js --passWithNoTests",
    "test:coverage": "vitest run --config vitest.config.js --coverage",
    "test:watch": "vitest --config vitest.config.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "http-proxy": "^1.18.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-fetch": "^2.6.7",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "prometheus-remote-write": "^0.5.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "supertest": "^7.2.2",
    "vitest": "^4.1.4"
  }
}
