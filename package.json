{
  "name": "vizme",
  "private": true,
  "scripts": {
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,css,md}\"",
    "format:frontend": "prettier --write \"frontend/src/**/*.{js,jsx,css}\"",
    "format:backend": "prettier --write \"backend/**/*.js\"",
    "test:pw": "playwright test",
    "test:pw:api": "playwright test tests/api",
    "test:pw:ui": "playwright test --ui",
    "test:pw:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "prettier": "^3.2.5",
    "typescript": "^5.7.2"
  }
}
