# Copy to .env and set real values. Required for backend and Docker Compose.

# Database (required)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=metrics_db
DB_USER=postgres
DB_PASSWORD=

# Production: use SSL and reject invalid certs
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# Auth (required in production: set a strong random secret, min 32 chars)
# Generate: openssl rand -base64 32
JWT_SECRET=

# URLs (required in production)
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000
# For Docker: backend uses grafana:3000. For local dev: http://localhost:3001
GRAFANA_URL=http://localhost:3001

# Grafana embed token expiry (e.g. 15m, 1h). Production: 15m. Dev: 1h for convenience.
# GRAFANA_EMBED_TOKEN_EXPIRY=15m

# CORS: restrict origins for metrics/tracker. Production: set explicit domains, never *
# ALLOWED_METRICS_ORIGINS=https://app.example.com,https://cdn.example.com,https://your-site.com

# Rate limits (requests per minute). Tune per tier in production.
# METRICS_RATE_LIMIT_MAX=500
# AUTH_RATE_LIMIT_MAX=5
# API_RATE_LIMIT_MAX=100
# GRAFANA_EMBED_RATE_LIMIT_MAX=30

# Grafana admin (required for multi-tenant Mimir). Must match Grafana's admin credentials.
# Backend uses these to create per-user orgs and Mimir datasources. Set both.
# If you change these after first run, reset Grafana: docker compose down && docker volume rm docker_grafana_data && docker compose up -d
# GF_SECURITY_ADMIN_USER=admin
# GF_SECURITY_ADMIN_PASSWORD=your-strong-password

# Optional: basic auth for Prometheus scraping /metrics. Set both to enable.
# METRICS_SCRAPE_USER=prometheus
# METRICS_SCRAPE_PASSWORD=generate-secure-password

# Label validation: prevent cardinality explosion (defaults: 10 labels, 128 chars/value, 1000 series/user)
# METRICS_MAX_LABELS=10
# METRICS_MAX_LABEL_VALUE_LENGTH=128
# METRICS_MAX_SERIES_PER_USER=1000

# Mimir (multi-tenant metrics with hard isolation)
# Docker: http://mimir:8080. Local dev: http://localhost:9009
# MIMIR_URL=http://mimir:8080

# Backend Grafana API (when backend runs in Docker, Grafana is at grafana:3000)
# GRAFANA_INTERNAL_URL=http://grafana:3000
