      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "{__name__=~\"user_metric_.+\", user_id=~\"^${user_id}$\"}",
          "refId": "A",
