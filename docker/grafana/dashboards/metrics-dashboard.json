{
  "dashboard": {
    "uid": "metrics",
  "title": "Vizme Metrics",
  "tags": [
    "vizme",
    "metrics",
    "ecommerce"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "user_id",
        "type": "textbox",
        "query": "",
        "current": {
          "selected": true,
          "text": "",
          "value": ""
        },
        "hide": 2,
        "skipUrlSync": false,
        "description": "Set by backend proxy from token (locked)"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP request rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"vizme-backend\"}[5m])) by (method, route, status)",
          "refId": "A",
          "legendFormat": "{{method}} {{route}} {{status}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "description": "Backend request rate (PromQL)"
    },
    {
      "id": 2,
      "title": "HTTP p99 latency (s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"vizme-backend\"}[5m])) by (le, route))",
          "refId": "A",
          "legendFormat": "{{route}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "description": "99th percentile request duration"
    },
    {
      "id": 7,
      "title": "Total revenue (NPR)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "increase(user_metric_total_revenue{user_id=~\"^${user_id}$\"}[24h]) or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          }
        }
      ],
      "description": "Total revenue in last 24h from completed orders (NPR)",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 1000
              },
              {
                "color": "green",
                "value": 5000
              }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 11,
      "title": "Orders completed (24h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "targets": [
        {
          "expr": "increase(user_metric_orders_completed{user_id=~\"^${user_id}$\"}[24h]) or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          }
        }
      ],
      "description": "Number of completed orders in last 24h",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
