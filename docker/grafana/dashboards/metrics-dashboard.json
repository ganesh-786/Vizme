{
  "dashboard": {
    "uid": "metrics",
    "title": "Vizme Metrics",
    "tags": [
      "vizme",
      "metrics",
      "ecommerce"
    ],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 3,
    "refresh": "15s",
    "templating": {
      "list": [
        {
          "name": "user_id",
          "type": "textbox",
          "query": "",
          "current": {
            "selected": true,
            "text": "",
            "value": ""
          },
          "hide": 2,
          "skipUrlSync": false,
          "description": "Set by backend proxy from token (locked)"
        },
        {
          "name": "site_filter",
          "type": "textbox",
          "query": "",
          "current": {
            "selected": true,
            "text": ".*",
            "value": ".*"
          },
          "hide": 2,
          "skipUrlSync": false,
          "description": "Set by the frontend property filter. Use .* to include all properties."
        }
      ]
    },
    "panels": [
      {
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "id": 100,
        "title": "Platform health",
        "type": "row"
      },
      {
        "id": 1,
        "title": "HTTP request rate",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 1
        },
        "targets": [
          {
            "expr": "vizme:http_requests:rate1m{service=\"vizme-backend\"}",
            "refId": "A",
            "legendFormat": "{{method}} {{route}} {{status}}",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "description": "Backend request rate from a 1-minute recording rule"
      },
      {
        "id": 2,
        "title": "HTTP p99 latency (s)",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 1
        },
        "targets": [
          {
            "expr": "vizme:http_request_duration:p99_1m{service=\"vizme-backend\"}",
            "refId": "A",
            "legendFormat": "{{route}}",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "description": "99th percentile request duration from a 1-minute recording rule"
      },
      {
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 9
        },
        "id": 101,
        "title": "Business overview",
        "type": "row"
      },
      {
        "id": 7,
        "title": "Total revenue (NPR)",
        "type": "stat",
        "datasource": {
          "type": "prometheus",
          "uid": "mimir"
        },
        "gridPos": {
          "h": 6,
          "w": 4,
          "x": 0,
          "y": 10
        },
        "targets": [
          {
            "expr": "sum(increase({__name__=~\"user_metric_(total_revenue|revenue|totalRevenue)\", user_id=~\"^${user_id}$\", site_id=~\"^${site_filter}$\"}[24h])) or vector(0)",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "mimir"
            }
          }
        ],
        "description": "Total revenue in last 24h from completed orders (NPR)",
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0,
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "orange",
                  "value": 1000
                },
                {
                  "color": "green",
                  "value": 5000
                }
              ]
            }
          }
        },
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "textMode": "value_and_name",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        }
      },
      {
        "id": 11,
        "title": "Orders completed (24h)",
        "type": "stat",
        "datasource": {
          "type": "prometheus",
          "uid": "mimir"
        },
        "gridPos": {
          "h": 6,
          "w": 4,
          "x": 4,
          "y": 10
        },
        "targets": [
          {
            "expr": "sum(increase({__name__=~\"user_metric_(orders_completed|checkout_completed)\", user_id=~\"^${user_id}$\", site_id=~\"^${site_filter}$\"}[24h])) or vector(0)",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "mimir"
            }
          }
        ],
        "description": "Successful checkouts in the last 24h from orders_completed or checkout_completed.",
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0,
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1
                },
                {
                  "color": "green",
                  "value": 5
                }
              ]
            }
          }
        },
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "textMode": "value_and_name",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
