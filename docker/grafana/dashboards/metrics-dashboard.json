{
  "dashboard": {
    "uid": "metrics",
    "title": "Vizme Metrics",
    "tags": [
      "vizme",
      "metrics"
    ],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 2,
    "refresh": "10s",
    "templating": {
      "list": [
        {
          "name": "user_id",
          "type": "textbox",
          "query": "",
          "current": {
            "selected": true,
            "text": "",
            "value": ""
          },
          "hide": 2,
          "skipUrlSync": false,
          "description": "Set by backend proxy from token (locked)"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "HTTP request rate",
        "type": "timeseries",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{service=\"vizme-backend\"}[5m])) by (method, route, status)",
            "refId": "A",
            "legendFormat": "{{method}} {{route}} {{status}}",
            "datasource": { "type": "prometheus", "uid": "prometheus" }
          }
        ],
        "description": "Backend request rate (PromQL)"
      },
      {
        "id": 2,
        "title": "HTTP p99 latency (s)",
        "type": "timeseries",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"vizme-backend\"}[5m])) by (le, route))",
            "refId": "A",
            "legendFormat": "{{route}}",
            "datasource": { "type": "prometheus", "uid": "prometheus" }
          }
        ],
        "description": "99th percentile request duration"
      },
      {
        "id": 3,
        "title": "User metric series count",
        "type": "stat",
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 0,
          "y": 8
        },
        "targets": [
          {
            "expr": "count(user_metric_*{user_id=~\"^${user_id}$\"})",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "mimir" }
          }
        ],
        "description": "Your metric series count (filtered by your user)"
      },
      {
        "id": 4,
        "title": "User metrics by user_id",
        "type": "timeseries",
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "gridPos": {
          "h": 8,
          "w": 18,
          "x": 6,
          "y": 8
        },
        "targets": [
          {
            "expr": "sum by (user_id, __name__) (rate(user_metric_*{user_id=~\"^${user_id}$\"}[5m]))",
            "refId": "A",
            "legendFormat": "{{user_id}} {{__name__}}",
            "datasource": { "type": "prometheus", "uid": "mimir" }
          }
        ],
        "description": "Rate of your metrics (filtered to your user only)."
      },
      {
        "id": 5,
        "title": "Cart items count (gauge)",
        "type": "stat",
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "max(user_metric_cart_items_count{user_id=~\"^${user_id}$\"}) or vector(0)",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "mimir" }
          }
        ],
        "description": "Current cart item count from ecommerce client"
      },
      {
        "id": 6,
        "title": "Cart value total (NPR)",
        "type": "stat",
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "gridPos": { "h": 6, "w": 6, "x": 6, "y": 16 },
        "targets": [
          {
            "expr": "max(user_metric_cart_value_total{user_id=~\"^${user_id}$\"}) or vector(0)",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "mimir" }
          }
        ],
        "description": "Current cart total value (NPR) from ecommerce client",
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        },
        "options": {
          "graphMode": "none",
          "colorMode": "value",
          "textMode": "value_and_name"
        }
      },
      {
        "id": 7,
        "title": "Total revenue (NPR)",
        "type": "stat",
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "gridPos": { "h": 6, "w": 6, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "sum(increase(user_metric_total_revenue{user_id=~\"^${user_id}$\"}[24h])) or vector(0)",
            "refId": "A",
            "datasource": { "type": "prometheus", "uid": "mimir" }
          }
        ],
        "description": "Total revenue in last 24h from completed orders (NPR)",
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0
          }
        },
        "options": {
          "graphMode": "none",
          "colorMode": "value",
          "textMode": "value_and_name"
        }
      },
      {
        "id": 8,
        "title": "Ecommerce gauges over time",
        "type": "timeseries",
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
        "targets": [
          {
            "expr": "user_metric_cart_items_count{user_id=~\"^${user_id}$\"}",
            "refId": "A",
            "legendFormat": "Cart items",
            "datasource": { "type": "prometheus", "uid": "mimir" }
          },
          {
            "expr": "user_metric_cart_value_total{user_id=~\"^${user_id}$\"}",
            "refId": "B",
            "legendFormat": "Cart value",
            "datasource": { "type": "prometheus", "uid": "mimir" }
          }
        ],
        "description": "Cart items and value over time (gauges)"
      },
      {
        "id": 9,
        "title": "Cart products (real-time per-product quantity)",
        "type": "table",
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
        "targets": [
          {
            "expr": "user_metric_cart_product_quantity{user_id=~\"^${user_id}$\"} > 0",
            "refId": "A",
            "format": "table",
            "instant": true,
            "datasource": { "type": "prometheus", "uid": "mimir" }
          }
        ],
        "description": "Quantity of each product in cart. Updates when you click +/- on cart page."
      },
      {
        "id": 10,
        "title": "Per-product quantities over time",
        "type": "timeseries",
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
        "targets": [
          {
            "expr": "user_metric_cart_product_quantity{user_id=~\"^${user_id}$\"}",
            "refId": "A",
            "legendFormat": "{{product_name}} ({{product_id}})",
            "datasource": { "type": "prometheus", "uid": "mimir" }
          }
        ],
        "description": "Quantity of each product in cart over time"
      }
    ]
  }
}