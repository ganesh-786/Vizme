      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 14
      },
      "targets": [
        {
          "expr": "count({__name__=~\"user_metric_.+\", user_id=~\"^${user_id}$\"}) or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          }
        }
